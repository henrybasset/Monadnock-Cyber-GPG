{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Monadnock Cyber GPG",
  "version": "0.1.0",
  "identifier": "com.monadnockcyber.gpg",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Monadnock Cyber GPG",
        "width": 580,
        "height": 800,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
