{
  "manifest_version": 3,
  "name": "Monadnock Cyber GPG",
  "version": "0.1.0",
  "description": "Encrypt, decrypt, and manage OpenPGP keys in your browser and webmail.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Monadnock Cyber GPG"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "contextMenus", "scripting", "activeTab"]
}
